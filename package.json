{
	"name": "gleetchy-mono",
	"version": "1.0.0",
	"private": true,
	"description": "looping business",
	"license": "ISC",
	"author": "Kav Singh <flakisms@gmail.com> (https://github.com/kavsingh)",
	"repository": {
		"type": "git",
		"url": "https://github.com/kavsingh/gleetchy.git"
	},
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		]
	},
	"type": "module",
	"scripts": {
		"dev": "nx dev gleetchy --outputStyle stream",
		"build": "nx build gleetchy",
		"test": "nx run-many -t test --outputStyle stream",
		"lint": "nx run-many -t lint --outputStyle stream",
		"clean:nx": "rimraf ./**/.nx --glob",
		"clean:modules": "rimraf ./**/node_modules --glob",
		"clean:types": "rimraf ./**/*.tsbuildinfo --glob"
	},
	"devDependencies": {
		"@total-typescript/ts-reset": "0.6.1",
		"@tsconfig/bun": "1.0.10",
		"@tsconfig/node24": "24.0.4",
		"@tsconfig/strictest": "2.0.8",
		"@types/bun": "1.3.13",
		"@typescript/native-preview": "7.0.0-dev.20260428.1",
		"concurrently": "9.2.1",
		"lefthook": "2.1.6",
		"nx": "22.7.0",
		"oxfmt": "0.47.0",
		"oxlint": "1.62.0",
		"oxlint-tsgolint": "0.22.1",
		"rimraf": "6.1.3"
	},
	"packageManager": "bun@1.3.13",
	"trustedDependencies": [
		"lefthook"
	]
}
