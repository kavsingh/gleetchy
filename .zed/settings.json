{
	"format_on_save": "on",
	"prettier": { "allowed": false },
	"formatter": [{ "language_server": { "name": "oxfmt" } }],
	"code_actions_on_format": { "source.fixAll.oxc": true },

	"lsp": {
		"oxlint": {
			"initialization_options": { "settings": { "typeAware": true } }
		},

		"tailwindcss-language-server": {
			"settings": {
				"validate": false,
				"classAttributes": [
					"class",
					"classList",
					"className",
					".+ClassName",
					".+ClassNames"
				],
				"classFunctions": ["tj", "tm"],
				"experimental": {
					"configFile": {
						"apps/gleetchy/src/index.css": "apps/gleetchy/src/**/*"
					}
				}
			}
		}
	},

	"languages": {
		"TypeScript": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"oxfmt",
				"tailwindcss-language-server"
			]
		},

		"TSX": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"oxfmt",
				"tailwindcss-language-server"
			]
		},

		"JavaScript": {
			"language_servers": ["tsgo", "oxlint", "oxfmt"]
		},

		"CSS": {
			"language_servers": [
				"tailwindcss-intellisense-css",
				"tailwindcss-language-server",
				"!vscode-css-language-server"
			]
		}
	}
}
